{
  "name": "ai-code-review-vscode",
  "displayName": "AI Code Review",
  "description": "Show AI review findings and apply fixes.",
  "version": "0.0.1",
  "publisher": "ai-code-review",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:aiCodeReview.issues",
    "onCommand:aiCodeReview.refresh",
    "onCommand:aiCodeReview.openIssue",
    "onCommand:aiCodeReview.showReport",
    "onCommand:aiCodeReview.copyFixPrompt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCodeReview.refresh",
        "title": "AI 代码审查: 刷新"
      },
      {
        "command": "aiCodeReview.openIssue",
        "title": "AI 代码审查: 打开问题"
      },
      {
        "command": "aiCodeReview.showReport",
        "title": "AI 代码审查: 查看报告"
      },
      {
        "command": "aiCodeReview.copyFixPrompt",
        "title": "AI 代码审查: 复制修复提示词"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiCodeReview",
          "title": "AI Code Review",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "aiCodeReview": [
        {
          "type": "webview",
          "id": "aiCodeReview.issues",
          "name": "问题列表"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aiCodeReview.refresh",
          "when": "view == aiCodeReview.issues",
          "group": "navigation@1"
        },
        {
          "command": "aiCodeReview.showReport",
          "when": "view == aiCodeReview.issues",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "AI Code Review",
      "properties": {
        "aiCodeReview.apiUrl": {
          "type": "string",
          "default": "http://localhost:8787",
          "description": "Backend API URL"
        },
        "aiCodeReview.pushUrl": {
          "type": "string",
          "default": "http://localhost:8787/review/stream",
          "description": "SSE push URL"
        },
        "aiCodeReview.provider": {
          "type": "string",
          "enum": ["claude", "openai", "gemini"],
          "default": "claude",
          "description": "Review model provider used by /review/run callers"
        },
        "aiCodeReview.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Review model name used by /review/run callers"
        }
      }
    }
  },
  "scripts": {
    "build:webview": "esbuild webview-src/main.tsx --bundle --format=iife --platform=browser --jsx=automatic --outfile=media/reviewView.js",
    "build": "tsc -p tsconfig.json && pnpm run build:webview",
    "lint": "oxlint src webview-src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/vscode": "^1.92.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
