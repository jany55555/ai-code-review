{
  "name": "ai-code-review-vscode",
  "displayName": "AI Code Review",
  "description": "Show AI review findings and apply fixes.",
  "version": "0.0.1",
  "publisher": "ai-code-review",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:aiCodeReview.issues",
    "onCommand:aiCodeReview.refresh",
    "onCommand:aiCodeReview.applyFix",
    "onCommand:aiCodeReview.openIssue",
    "onCommand:aiCodeReview.showReport",
    "onCommand:aiCodeReview.copyFixPrompt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCodeReview.refresh",
        "title": "AI 代码审查: 刷新"
      },
      {
        "command": "aiCodeReview.applyFix",
        "title": "AI 代码审查: 修复"
      },
      {
        "command": "aiCodeReview.openIssue",
        "title": "AI 代码审查: 打开问题"
      },
      {
        "command": "aiCodeReview.showReport",
        "title": "AI 代码审查: 查看报告"
      },
      {
        "command": "aiCodeReview.copyFixPrompt",
        "title": "AI 代码审查: 复制修复提示词"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiCodeReview",
          "title": "AI Code Review",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "aiCodeReview": [
        {
          "id": "aiCodeReview.issues",
          "name": "问题列表"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "aiCodeReview.openIssue",
          "when": "view == aiCodeReview.issues && viewItem == ai-code-review-issue",
          "group": "inline"
        },
        {
          "command": "aiCodeReview.applyFix",
          "when": "view == aiCodeReview.issues && viewItem == ai-code-review-issue",
          "group": "inline@1"
        },
        {
          "command": "aiCodeReview.copyFixPrompt",
          "when": "view == aiCodeReview.issues && viewItem == ai-code-review-issue",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "command": "aiCodeReview.refresh",
          "when": "view == aiCodeReview.issues",
          "group": "navigation@1"
        },
        {
          "command": "aiCodeReview.showReport",
          "when": "view == aiCodeReview.issues",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "AI Code Review",
      "properties": {
        "aiCodeReview.apiUrl": {
          "type": "string",
          "default": "http://localhost:8787",
          "description": "Backend API URL"
        },
        "aiCodeReview.pushUrl": {
          "type": "string",
          "default": "http://localhost:8787/review/stream",
          "description": "SSE push URL"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "oxlint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.9.2"
  }
}
